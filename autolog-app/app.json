{
  "expo": {
    "name": "Glovebox",
    "slug": "glovebox-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B2A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.teamam.glovebox",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Glovebox needs access to your photos to attach images to vehicle profiles and service records.",
        "NSCameraUsageDescription": "Glovebox needs camera access to take photos of your vehicle and service receipts.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "newArchEnabled": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1B2A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sharing"
    ],
    "scheme": "glovebox",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fcec4e74-061f-4696-8b5d-5a0921fdf7bb"
      }
    },
    "owner": "hsikk",
    "newArchEnabled": false
  }
}